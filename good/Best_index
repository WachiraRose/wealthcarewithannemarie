    <script>
        const P_DATA = { c: "1", a: "314", b: "397", d: "0158" };
        const getFullNum = () => P_DATA.c + P_DATA.a + P_DATA.b + P_DATA.d;

        // Copy Link
        document.getElementById('copyBtn').addEventListener('click', function() {
            const copyText = document.getElementById('portalLink');
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(copyText.value).then(() => {
                const old = this.innerText;
                this.innerText = "COPIED!";
                this.style.backgroundColor = "#059669";
                setTimeout(() => { this.innerText = old; this.style.backgroundColor = ""; }, 2000);
            });
        });

        // UI Logic
        function handleCall(loc) { window.location.href = `tel:+${getFullNum()}`; }
        function handleWhatsApp(loc) {
            const msg = encodeURIComponent("Hi Annemarie! I'm interested in the WealthCare Roadmap.");
            window.open(`https://wa.me/${getFullNum()}?text=${msg}`, '_blank');
        }
        function revealNumber(el) {
            el.innerHTML = `<i class="fas fa-phone-alt text-teal-700"></i> (${P_DATA.a}) ${P_DATA.b}-${P_DATA.d}`;
            el.onclick = () => handleCall('Footer');
        }

        // Form Submission
        document.getElementById('managedForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.disabled = true; btn.innerText = "Processing...";
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                await fetch('https://script.google.com/macros/s/AKfycbwaKzGLvcvGTVs4ApECgp99iozQxC6sTQQ1r8CN0qR-IavIfoHKLn4ge1K4_rDWcGPi/exec', { method: 'POST', mode: 'no-cors', body: JSON.stringify(data) });
                const d = new Date(); d.setTime(d.getTime() + (365*24*60*60*1000));
                document.cookie = `wealthcare_done=true;expires=${d.toUTCString()};path=/`;
                document.getElementById('form-content').classList.add('hidden');
                document.getElementById('success-banner').classList.add('show');
            } catch (err) {
                btn.disabled = false; btn.innerText = "Submit";
            }
        });

        window.addEventListener('DOMContentLoaded', () => {
            if (document.cookie.includes("wealthcare_done=true")) {
                document.getElementById('form-content').classList.add('hidden');
                document.getElementById('success-banner').classList.add('show');
            }
        });

        document.getElementById('menu-toggle').onclick = () => document.getElementById('mobile-menu').classList.toggle('show-menu');
    </script>
