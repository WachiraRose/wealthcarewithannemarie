<body class="bg-white text-gray-900">

    <div class="action-bar md:hidden">
        <a href="javascript:void(0)" onclick="handleCall('Mobile Bar')" class="flex-1 bg-teal-900 text-white text-center btn-sm-mobile font-bold flex items-center justify-center gap-2 shadow-xl border border-white/10">
            <i class="fas fa-phone-alt text-xs"></i> Call
        </a>
        <a href="javascript:void(0)" onclick="handleWhatsApp('Mobile Bar')" class="flex-1 bg-[#25D366] text-white text-center btn-sm-mobile font-bold flex items-center justify-center gap-2 shadow-xl border border-white/10">
            <i class="fab fa-whatsapp text-sm"></i> Chat
        </a>
    </div>

    <nav class="fixed top-0 w-full z-50 glass-nav border-b border-gray-100 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 md:px-6 py-3 flex justify-between items-center">
            <a href="#" class="flex items-center gap-3">
                <img src="img/logo.jpg" alt="Logo" class="h-10 w-10 md:h-12 md:w-12 rounded-full object-cover">
                <span class="font-extrabold tracking-tighter text-sm md:text-xl uppercase italic text-teal-900 leading-none">Wealthcare<br class="block md:hidden"><span class="font-light not-italic text-gray-500">WithAnnemarie</span></span>
            </a>
            
            <div class="hidden lg:flex items-center gap-4">
                <a href="javascript:void(0)" onclick="handleCall('Desktop Nav')" class="text-teal-900 font-bold text-xs flex items-center gap-2 hover:opacity-70 transition">
                    <i class="fas fa-phone-alt"></i> Call
                </a>
                <a href="javascript:void(0)" onclick="handleWhatsApp('Desktop Nav')" class="bg-[#25D366] text-white px-4 py-1.5 rounded-full font-bold text-xs flex items-center gap-2 hover:shadow-md transition">
                    <i class="fab fa-whatsapp"></i> Chat with Annemarie
                </a>
                <a href="#contact" class="bg-teal-900 text-white px-5 py-1.5 rounded-full font-bold uppercase text-[10px] tracking-widest">Access</a>
            </div>
        </div>
    </nav>

    <header class="hero-bg min-h-screen flex items-center justify-center text-center px-4 md:px-6 pt-20">
        <div class="max-w-4xl text-white">
            <span class="text-teal-300 font-extrabold tracking-[0.3em] uppercase text-xs mb-6 block">Legacy • Protection • Growth</span>
            <h1 class="text-4xl md:text-7xl mb-8 leading-tight font-bold">Financial Literacy is the <br><span class="italic text-teal-200">New Currency</span></h1>
            <p class="text-lg md:text-xl mb-12 font-light max-w-3xl mx-auto leading-relaxed">Educating families to build generational bridges across all backgrounds.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="#contact" class="bg-white text-teal-900 px-10 py-4 rounded-xl font-extrabold text-base shadow-2xl hover:bg-gray-100 transition">Start Here</a>
                <a href="https://calendly.com/amariem/one-on-one" target="_blank" onclick="trackEvent('Calendly', 'Hero')" class="bg-teal-900/60 backdrop-blur-md border border-white/30 text-white px-10 py-4 rounded-xl font-extrabold text-base hover:bg-white/10 transition">Book Call</a>
            </div>
        </div>
    </header>

    <section id="contact" class="py-20 bg-[#f4f1ea] px-4 md:px-6 pb-40 md:pb-20">
        <div class="max-w-4xl mx-auto bg-white rounded-[2rem] p-8 md:p-14 shadow-2xl border border-gray-100 relative min-h-[400px] flex flex-col justify-center">
            
            <div id="success-banner" class="bg-teal-50 border border-teal-100 rounded-2xl p-6 md:p-10 text-center">
                <div class="flex items-center justify-center gap-3 text-teal-900 mb-6">
                    <i class="fas fa-check-circle text-4xl text-teal-600"></i>
                    <span class="font-bold text-xl md:text-2xl text-teal-900">Welcome Back!</span>
                </div>
                <p class="text-teal-800 font-medium text-base mb-8">Your roadmap is ready. Need immediate help?</p>

                <div class="flex flex-wrap justify-center gap-3 mb-10">
                    <a href="javascript:void(0)" onclick="handleWhatsApp('Success Banner')" class="flex items-center gap-2 bg-white text-[#25D366] px-5 py-2.5 rounded-lg font-bold border border-[#25D366]/20 hover:bg-[#25D366] hover:text-white transition text-sm">
                        <i class="fab fa-whatsapp"></i> Chat with Annemarie
                    </a>
                    <a href="javascript:void(0)" onclick="handleCall('Success Banner')" class="flex items-center gap-2 bg-teal-100 text-teal-900 px-5 py-2.5 rounded-lg font-bold hover:bg-teal-900 hover:text-white transition text-sm">
                        <i class="fas fa-phone-alt"></i> Quick Call
                    </a>
                </div>

                <div class="max-w-xs mx-auto">
                    <p class="text-[10px] uppercase tracking-widest font-bold text-teal-700 mb-2">Portal Link:</p>
                    <div class="flex items-center gap-2 bg-white border border-teal-100 p-2 rounded-lg shadow-inner">
                        <input type="text" id="copyInput" value="https://wealthcare-portal.com/access" readonly class="bg-transparent border-none text-gray-500 text-xs px-2 w-full outline-none">
                        <button id="copyBtn" class="bg-teal-900 text-white px-3 py-1.5 rounded-md text-[10px] font-bold uppercase">Copy</button>
                    </div>
                </div>
            </div>

            <div id="form-content">
                <div class="text-center mb-10">
                    <h2 class="text-2xl md:text-3xl mb-3 text-teal-900 font-bold">Secure Your Roadmap</h2>
                    <p class="text-gray-500 text-sm">Instant access to your family financial portal.</p>
                </div>
                <form id="managedForm" class="space-y-3">
                    <div class="grid md:grid-cols-2 gap-3">
                        <input type="text" name="first_name" placeholder="First Name" required class="w-full px-5 py-3.5 rounded-xl bg-gray-50 border-none outline-none focus:ring-2 focus:ring-teal-800 text-sm">
                        <input type="text" name="last_name" placeholder="Last Name" required class="w-full px-5 py-3.5 rounded-xl bg-gray-50 border-none outline-none focus:ring-2 focus:ring-teal-800 text-sm">
                    </div>
                    <input type="email" name="email" placeholder="Email Address" required class="w-full px-5 py-3.5 rounded-xl bg-gray-50 border-none outline-none focus:ring-2 focus:ring-teal-800 text-sm">
                    <input type="tel" name="phone" placeholder="Phone Number" required class="w-full px-5 py-3.5 rounded-xl bg-gray-50 border-none outline-none focus:ring-2 focus:ring-teal-800 text-sm">
                    <button type="submit" id="submitBtn" class="w-full bg-teal-900 text-white font-bold py-4 rounded-xl hover:bg-teal-700 transition shadow-lg uppercase text-sm tracking-widest">Get Access Now</button>
                </form>
            </div>
        </div>
    </section>

    <footer class="bg-white border-t border-gray-100 py-12 px-4 md:px-6">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 text-center md:text-left">
            <div>
                <img src="img/logo.jpg" alt="Logo" class="h-12 w-12 rounded-full mb-4 mx-auto md:mx-0">
                <h3 class="font-bold text-teal-900 text-lg">Wealthcare With Annemarie</h3>
                <p class="text-gray-500 text-xs">St. Louis, Missouri</p>
            </div>
            <div class="flex flex-col gap-3">
                <h4 class="font-bold text-teal-900 uppercase text-[10px] tracking-widest mb-2">Connect Safely</h4>
                <a href="javascript:void(0)" onclick="revealNumber(this)" class="text-gray-500 text-xs hover:text-teal-900 flex items-center justify-center md:justify-start gap-2">
                    <i class="fas fa-lock opacity-30"></i> Click to reveal phone
                </a>
                <a href="javascript:void(0)" onclick="handleWhatsApp('Footer')" class="text-gray-500 text-xs hover:text-[#25D366] flex items-center justify-center md:justify-start gap-2">
                    <i class="fab fa-whatsapp"></i> Chat with Annemarie
                </a>
            </div>
            <div>
                <p class="text-[10px] text-gray-400 leading-relaxed max-w-xs mx-auto md:mx-0">
                    &copy; 2026 WealthCare. Financial education services. All conversations are private and protected.
                </p>
            </div>
        </div>
    </footer>

    <script>
        // --- DATA PROTECTION ---
        const P_DATA = { c: "1", a: "314", b: "123", d: "4567" };
        const getFullNum = () => P_DATA.c + P_DATA.a + P_DATA.b + P_DATA.d;

        // --- ACTIONS ---
        function handleCall(loc) {
            trackEvent('Call', loc);
            window.location.href = `tel:+${getFullNum()}`;
        }

        function handleWhatsApp(loc) {
            trackEvent('WhatsApp', loc);
            const msg = encodeURIComponent("Hi Annemarie! I'm interested in the WealthCare Roadmap.");
            // Open the WhatsApp link
            window.open(`https://wa.me/${getFullNum()}?text=${msg}`, '_blank');
        }

        function revealNumber(el) {
            const formatted = `(${P_DATA.a}) ${P_DATA.b}-${P_DATA.d}`;
            el.innerHTML = `<i class="fas fa-phone-alt text-teal-700"></i> ${formatted}`;
            el.onclick = () => handleCall('Footer Revealed');
            trackEvent('Number Revealed', 'Footer');
        }

        function trackEvent(type, label) {
            if(typeof gtag === 'function') {
                gtag('event', 'interaction', { 'event_category': type, 'event_label': label });
            }
        }

        // --- COOKIE & FORM LOGIC ---
        const setSubCookie = () => {
            const d = new Date();
            d.setTime(d.getTime() + (365*24*60*60*1000));
            document.cookie = `wealthcare_done=true;expires=${d.toUTCString()};path=/`;
        };
        const getSubCookie = () => document.cookie.split('; ').find(row => row.startsWith('wealthcare_done='))?.split('=')[1];

        window.addEventListener('DOMContentLoaded', () => {
            if (getSubCookie() === "true") {
                document.getElementById('form-content').classList.add('hidden');
                document.getElementById('success-banner').classList.add('show');
            }
        });

        document.getElementById('copyBtn').addEventListener('click', function() {
            const input = document.getElementById('copyInput');
            input.select();
            navigator.clipboard.writeText(input.value).then(() => {
                this.innerText = "Done!";
                setTimeout(() => this.innerText = "Copy", 2000);
            });
        });

        document.getElementById('managedForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerText = "Securing...";

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                await fetch('https://script.google.com/macros/s/AKfycbwaKzGLvcvGTVs4ApECgp99iozQxC6sTQQ1r8CN0qR-IavIfoHKLn4ge1K4_rDWcGPi/exec', { 
                    method: 'POST', 
                    mode: 'no-cors', 
                    body: JSON.stringify(data) 
                });
                
                setSubCookie();
                document.getElementById('form-content').classList.add('hidden');
                document.getElementById('success-banner').classList.add('show');
            } catch (err) {
                btn.disabled = false;
                btn.innerText = "Submit";
                alert("Please check your connection.");
            }
        });
    </script>
</body>
</html>
